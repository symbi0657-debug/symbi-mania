# ─────────────────────────────────────────────────────────────────────────────
#  SYMBI FRESHO Mania 3.0 — environment
#  Copy to .env.local and fill in. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# --- Site ---
# Must be the real public https URL in production. It is baked into the QR
# codes on every issued pass, AND it is what Cashfree redirects buyers back to
# after payment. If it is wrong, passes 404 at the gate and buyers never return
# from checkout.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Upstash Redis (REQUIRED — all tickets, counters and inventory live here) ---
# From https://console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token

# ─────────────────────────────────────────────────────────────────────────────
#  CASHFREE PAYMENT GATEWAY (REQUIRED — this is how you get paid)
# ─────────────────────────────────────────────────────────────────────────────
# Get these from https://merchant.cashfree.com
#   → Developers → API Keys → Generate/Copy
#
# There are TWO separate key pairs, one per environment. Copy the pair that
# matches CASHFREE_MODE below — mixing them gives "authentication failed".
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# "sandbox" (test money, test cards) or "production" (real money).
# Defaults to sandbox if unset, deliberately: the failure mode of the reverse
# default is charging real cards from a staging deploy.
#
# Flip to production ONLY after your Cashfree account is activated (KYC done)
# and you've completed one successful sandbox payment end to end.
CASHFREE_MODE=sandbox

# One more step, and it is NOT an env var — do it in the Cashfree dashboard:
#   Developers → Webhooks → Add webhook endpoint
#   URL:  https://YOUR-DOMAIN/api/webhooks/cashfree
#   Event: Payment Success
# This is what issues the pass for buyers who close the tab before being
# redirected back — on mobile, that's most of them. Without it those buyers
# still get their pass, but only once the 10-minute sweeper picks them up.
# No extra secret to configure: the webhook is signed with CASHFREE_SECRET_KEY.

# --- Secrets (REQUIRED) ---
# Generate each with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# SESSION_SECRET signs admin session cookies. Rotating it logs everyone out.
SESSION_SECRET=
# TICKET_SIGNING_SECRET signs pass QR links. Rotating it invalidates the
# signature on every pass already emailed out — do not rotate after launch.
TICKET_SIGNING_SECRET=
# Protects the cron endpoint, which returns unsold seats to inventory.
CRON_SECRET=

# --- Admin access (REQUIRED) ---
# Full admin: dashboard, tickets, buyer PII, referrals.
ADMIN_PASSWORD=
# Optional lower-privilege password for gate crew — check-in screen only.
# Give this one to volunteers; never share ADMIN_PASSWORD at the door.
GATE_PASSWORD=

# --- Email (REQUIRED — this is how buyers receive their pass) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
# Gmail app password (16 chars), NOT your account password.
SMTP_PASS=
SMTP_FROM="SYMBI FRESHO Mania 3.0 <your_email@gmail.com>"
